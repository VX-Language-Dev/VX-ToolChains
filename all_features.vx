# ============================================================
# 演示函数 - 嵌套控制流与复杂场景
# ============================================================
func demo_nested()
    mut result: int = 0
    for i in range
        if i == 0
            continue
        if i % 2 == 0
            result = result + i
        else
            result = result - i
        if result > 100
            break
    return result

func demo_deeply_nested()
    mut i: int = 0
    while i < 10
        if i % 2 == 0
            i = i + 1
        else
            i = i + 2

# ============================================================
# 演示函数 - 函数作为参数 (高阶函数)
# ============================================================
func apply(f: pointer, x: int) -> int
    return x

func compose(f: pointer, g: pointer, x: int) -> int
    return x


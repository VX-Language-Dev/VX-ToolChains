{
  "name": "vx-language",
  "displayName": "VX Language",
  "description": "Syntax highlighting and LSP integration for the VX programming language",
  "version": "1.6.0",
  "publisher": "vx-language-team",
  "license": "AGPL-3.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Language Packs",
    "Debuggers",
    "Formatters"
  ],
  "keywords": [
    "vx",
    "language",
    "lsp"
  ],
  "activationEvents": [
    "onLanguage:vx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "vx",
        "aliases": [
          "VX",
          "vx"
        ],
        "extensions": [
          ".vx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/vx.svg",
          "dark": "./icons/vx.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "vx",
        "scopeName": "source.vx",
        "path": "./syntaxes/vx.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "VX Language",
      "properties": {
        "vx.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to the vx-lsp executable. If empty, the extension tries to build and use target/release/vx-lsp from the workspace root."
        },
        "vx.languageServer.trace": {
          "type": "boolean",
          "default": false,
          "description": "Trace LSP client/server communication to the VX Language output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}

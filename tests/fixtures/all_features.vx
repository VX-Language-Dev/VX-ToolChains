# ========================================================================
# 第十三部分：宏系统
# ========================================================================

macro twice(x)
    x + x

macro max(a, b)
    if a > b then a else b

macro assert(cond, msg)
    if not cond
        sys_print(msg)

func test_macros()
    r1: int = #twice(5)
    r2: int = #max(10, 20)
    #assert(1 == 1, "should not trigger")
    return

# ========================================================================
# 第十四部分：嵌套控制流与复杂场景
# ========================================================================

func nested_control_flow()
    mut result: int = 0
    mut i: int = 0

    while i < 10
        if i == 0
            continue
        if i % 2 == 0
            result = result + i
        else
            result = result - i
        if result > 100
            break
        i = i + 1

    return result

func nested_ifs(x: int, y: int) -> int
    if x > 0
        if y > 0
            return x + y
        elif y == 0
            return x
        else
            return x - y
    else
        if y > 0
            return y
        else
            return 0

# ========================================================================
# 第十五部分：运算符优先级验证
# ========================================================================

func precedence_test()
    # 乘除优先于加减
    r1: int = 1 + 2 * 3
    r2: int = (1 + 2) * 3

    # 比较优先于逻辑
    r3: bool = 1 < 2 and 3 > 4

    # 一元负号
    r4: int = -5 + 3
    r5: bool = not false and true

    # 幂运算右结合
    r6: int = 2 ^ 3 ^ 2

    # 复合赋值
    mut x: int = 10
    x += 5
    x -= 3
    x *= 2
    x /= 4
    return

# ========================================================================
# 第十六部分：函数作为一级公民（组合使用）
# ========================================================================

func fib(n: int) -> int
    if n <= 1
        return n
    return fib(n - 1) + fib(n - 2)

func factorial(n: int) -> int
    if n <= 1
        return 1
    return n * factorial(n - 1)

func test_recursion()
    f10: int = fib(10)
    f5: int = factorial(5)
    return

# ========================================================================
# 第十七部分：综合 - 完整程序入口
# ========================================================================

func main() -> int
    # 单元测试入口
    basic_literals()
    mutability()
    operators()
    control_flow()

    # 函数调用
    r: int = add(40, 2)
    r2: int = calculate(1, 2, 3)
    r3: int = abs(-5)
    test_calls()

    # 复合类型
    test_structs()
    test_classes()
    test_enums()
    test_unions()

    # 数组和映射
    arrays_and_maps()

    # 内存和所有权
    memory_basics()
    borrowing()
    move_semantics()
    ownership_complex()

    # 嵌套控制流
    nr: int = nested_control_flow()
    nr2: int = nested_ifs(1, -1)

    # 递归
    f: int = fib(10)
    fact: int = factorial(5)

    # 宏
    test_macros()

    return 0

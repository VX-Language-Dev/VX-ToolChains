# ========================================================================
# VX Language - 完整功能展示
# 涵盖：词法、语法、类型系统、控制流、函数、复合类型、所有权、宏、导入
# ========================================================================

import std.io
import std.collections.vec as vec
import std.memory

# ========================================================================
# 第一部分：基本语法 - 变量声明与字面量
# ========================================================================

func basic_literals()
    # 整数
    a: int = 42
    b: int = 0
    c: int = 10000

    # 浮点数
    d: float = 3.14
    e: float = 0.5
    f: float = 1e10
    g: float = 2.5e-3

    # 字符串
    s1: string = "hello world"
    s2: string = 'single quoted'
    s3: string = "line1\nline2"

    # 布尔
    t: bool = true
    f_: bool = false

    # 空值
    n: pointer = nil
    return

# ========================================================================
# 第二部分：可变性与赋值
# ========================================================================

func mutability()
    # 不可变变量（默认）
    x: int = 10

    # 可变变量
    mut y: int = 20
    y = 30
    y += 5
    y -= 3
    y *= 2
    y /= 4
    y %= 3
    return

# ========================================================================
# 第三部分：运算符
# ========================================================================

func operators()
    # 算术运算
    add: int = 1 + 2
    sub: int = 10 - 3
    mul: int = 4 * 5
    div: int = 20 / 3
    mod: int = 17 % 5
    pow: int = 2 ^ 10

    # 比较运算
    eq: bool = 1 == 1
    ne: bool = 2 != 3
    lt: bool = 1 < 2
    gt: bool = 3 > 1
    le: bool = 2 <= 2
    ge: bool = 3 >= 2

    # 逻辑运算（关键字形式）
    land: bool = true and false
    lor: bool = true or false
    lnot: bool = not true

    # 逻辑运算（符号形式）
    sand: bool = true && false
    sor: bool = true || false
    snot: bool = !true

    # 混合表达式与优先级
    r1: int = 1 + 2 * 3 - 4 / 2
    r2: int = (1 + 2) * 3
    r3: bool = 1 < 2 and 3 > 4 or not false
    return

# ========================================================================
# 第四部分：控制流
# ========================================================================

func control_flow()
    mut x: int = 0
    mut result: int = 0

    # if / elif / else
    if x > 0
        result = 1
    elif x < 0
        result = -1
    else
        result = 0

    # 多行条件
    a: int = 5
    b: int = 10
    c: int = 15
    if a > 0 or
       b > 0 or
       c > 0
        a = 1

    # while 循环
    mut i: int = 0
    while i < 10
        i = i + 1

    # for 循环（迭代器）
    total: int = 0
    for item in items
        total = total + item

    # loop 循环（无限循环，带 label）
    mut count: int = 0
    loop outer
        count = count + 1
        if count > 5
            break outer
        if count % 2 == 0
            continue
    return

# ========================================================================
# 第五部分：函数
# ========================================================================

# 无参数无返回值
func greet()
    sys_print("hello")
    return

# 带参数
func add(a: int, b: int) -> int
    return a + b

# 多参数
func calculate(a: int, b: int, c: int) -> int
    return a + b * c

# 无返回值（void）
func abort()
    return

# 嵌套调用
func nested_call() -> int
    r: int = add(add(1, 2), add(3, 4))
    return r

# 带多个 return
func abs(x: int) -> int
    if x >= 0
        return x
    else
        return -x

# 关键字作为函数名（自举兼容）
func new() -> int
    return 1

func return_() -> int
    return 0

func test_calls()
    r1: int = add(1, 2)
    r2: int = add(r1, 3)
    r3: int = nested_call()
    return

# ========================================================================
# 第六部分：结构体
# ========================================================================

struct Point:
    x: int
    y: int
    func area() -> int
        return self.x * self.y

struct Color:
    r: int
    g: int
    b: int
    a: int

# 泛型结构体
struct Pair<T>:
    first: T
    second: T

struct Option<T>:
    value: T
    has_value: bool

# 带方法的结构体
struct Rectangle:
    width: int
    height: int
    func area() -> int
        return self.width * self.height
    func perimeter() -> int
        return 2 * (self.width + self.height)
    func is_square() -> bool
        return self.width == self.height

func test_structs()
    # 创建和使用结构体
    p: Point
    p.x = 3
    p.y = 4
    a: int = p.x
    area: int = p.area()

    # 指针成员访问
    ptr: pointer = &p
    px: int = ptr->x
    py: int = ptr->y
    return

# ========================================================================
# 第七部分：类（继承）
# ========================================================================

class Animal:
    name: string
    age: int

# 继承
class Dog : Animal:
    breed: string
    func bark()
        sys_print("woof")

class Cat : Animal:
    color: string
    func meow()
        sys_print("meow")

# 含默认值字段
class Counter:
    count: int = 0
    func increment()
        self.count = self.count + 1
    func get() -> int
        return self.count

func test_classes()
    dog: Dog
    dog.name = "Rex"
    dog.age = 3
    dog.breed = "Labrador"

    cat: Cat
    cat.name = "Whiskers"
    cat.color = "black"
    return

# ========================================================================
# 第八部分：枚举
# ========================================================================

enum Color:
    Red
    Green
    Blue
    Yellow

# 枚举带值
enum Status:
    OK = 200
    NotFound = 404
    Error = 500
    Unauthorized = 401

enum Direction:
    North = 0
    East = 1
    South = 2
    West = 3

func test_enums()
    c: Color = Color.Red
    s: Status = Status.OK
    d: Direction = Direction.North
    return

# ========================================================================
# 第九部分：联合体
# ========================================================================

union Value:
    i: int
    f: float
    b: bool

union Number:
    integer: int
    real: float

func test_unions()
    v: Value
    v.i = 42
    return

# ========================================================================
# 第十部分：数组与映射
# ========================================================================

func arrays_and_maps()
    # 数组字面量
    arr1: array = [1, 2, 3, 4, 5]
    arr2: array = []
    arr3: array = [1]

    # 索引访问
    first: int = arr1[0]
    last: int = arr1[4]

    # 映射字面量
    map1: map = {"name": "VX", "version": "1.0"}
    map2: map = {}

    # 映射访问
    name: string = map1["name"]
    return

# ========================================================================
# 第十一部分：指针、引用与所有权
# ========================================================================

func memory_basics()
    # 堆分配
    p: pointer = new int
    *p = 42
    v: int = *p
    free(p)
    return

func new_with_args()
    p: pointer = new Point(10, 20)
    px: int = p->x
    py: int = p->y
    free(p)
    return

func borrowing()
    mut x: int = 1

    # 不可变借用（多次允许）
    r1: pointer = &x
    r2: pointer = &x

    # 可变借用
    r3: pointer = &mut x
    *r3 = 42
    return

func move_semantics()
    # 指针类型：move 转移所有权
    a: pointer = new int
    b: pointer = move a

    # 标量类型：Copy 语义，不会 move
    c: int = 10
    d: int = c
    e: int = c

    # 浮点也是 Copy
    f: float = 3.14
    g: float = f
    h: float = f
    return

func ownership_complex()
    mut heap: pointer = new int
    r: pointer = &mut heap
    *r = 100
    v: int = *r
    free(heap)
    return


# Struct and Class test
struct Point:
    x: int
    y: int

func main():
    # test struct
    p: Point = new Point(10, 20)
    out(p.x)   # expect: 10
    out(p.y)   # expect: 20

    p.x = 30
    out(p.x)   # expect: 30

    # test another instance
    var q = new Point(5, 15)
    out(q.x)   # expect: 5
